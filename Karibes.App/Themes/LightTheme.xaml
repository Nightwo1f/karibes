<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryBlack">#FFFFFF</Color>
    <Color x:Key="SecondaryBlack">#F7F8FA</Color>
    <Color x:Key="PrimaryYellow">#FFD400</Color>
    <Color x:Key="TextLight">#171717</Color>
    <Color x:Key="HoverYellow">#FFE066</Color>
    <Color x:Key="PressedYellow">#D6B300</Color>
    <Color x:Key="ErrorRed">#DC3545</Color>
    <Color x:Key="ErrorRedDark">#B02A37</Color>
    <Color x:Key="WarningOrange">#FFA500</Color>
    <Color x:Key="White">#FFFFFF</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryBlack}"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource SecondaryBlack}"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource TextLight}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryYellow}"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#171717"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverYellow}"/>
    <SolidColorBrush x:Key="PressedBrush" Color="{StaticResource PressedYellow}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#D8DDE6"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5F6B7A"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLight}"/>
    <SolidColorBrush x:Key="TextDarkBrush" Color="#000000"/>
    <SolidColorBrush x:Key="PrimaryBlackBrush" Color="#171717"/>
    <SolidColorBrush x:Key="TabActiveBrush" Color="{StaticResource PrimaryYellow}"/>
    <SolidColorBrush x:Key="TabInactiveBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="TabHoverBrush" Color="#EDF1F5"/>
    <SolidColorBrush x:Key="ErrorRedBrush" Color="{StaticResource ErrorRed}"/>
    <SolidColorBrush x:Key="ErrorRedDarkBrush" Color="{StaticResource ErrorRedDark}"/>
    <SolidColorBrush x:Key="WarningOrangeBrush" Color="{StaticResource WarningOrange}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ReadOnlyBackgroundBrush" Color="#EEF1F5"/>
    <SolidColorBrush x:Key="RowAlternateBrush" Color="#F0F3F7"/>
    <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#E8ECF2"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="#FFE58A"/>
    <SolidColorBrush x:Key="SelectionForegroundBrush" Color="#171717"/>

</ResourceDictionary>
