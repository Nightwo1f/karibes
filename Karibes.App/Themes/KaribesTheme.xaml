<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryBlack">#101010</Color>
    <Color x:Key="SecondaryBlack">#1D1D1D</Color>
    <Color x:Key="PrimaryYellow">#FFD400</Color>
    <Color x:Key="TextLight">#F7F7F2</Color>
    <Color x:Key="HoverYellow">#FFE45C</Color>
    <Color x:Key="PressedYellow">#C9A700</Color>
    <Color x:Key="ErrorRed">#E5484D</Color>
    <Color x:Key="ErrorRedDark">#B93136</Color>
    <Color x:Key="WarningOrange">#FFB020</Color>
    <Color x:Key="White">#FFFFFF</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryBlack}"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource SecondaryBlack}"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource TextLight}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#181818"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryYellow}"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#101010"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverYellow}"/>
    <SolidColorBrush x:Key="PressedBrush" Color="{StaticResource PressedYellow}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3A3520"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#D2D0C8"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLight}"/>
    <SolidColorBrush x:Key="TextDarkBrush" Color="#000000"/>
    <SolidColorBrush x:Key="PrimaryBlackBrush" Color="#101010"/>
    <SolidColorBrush x:Key="TabActiveBrush" Color="{StaticResource PrimaryYellow}"/>
    <SolidColorBrush x:Key="TabInactiveBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="TabHoverBrush" Color="#2A2617"/>
    <SolidColorBrush x:Key="ErrorRedBrush" Color="{StaticResource ErrorRed}"/>
    <SolidColorBrush x:Key="ErrorRedDarkBrush" Color="{StaticResource ErrorRedDark}"/>
    <SolidColorBrush x:Key="WarningOrangeBrush" Color="{StaticResource WarningOrange}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#171717"/>
    <SolidColorBrush x:Key="ReadOnlyBackgroundBrush" Color="#232018"/>
    <SolidColorBrush x:Key="RowAlternateBrush" Color="#171717"/>
    <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#242014"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="#7A6500"/>
    <SolidColorBrush x:Key="SelectionForegroundBrush" Color="#FFFFFF"/>

</ResourceDictionary>
