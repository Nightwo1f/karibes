<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryBlack">#151719</Color>
    <Color x:Key="SecondaryBlack">#22262A</Color>
    <Color x:Key="PrimaryYellow">#F2C94C</Color>
    <Color x:Key="TextLight">#F4F6F8</Color>
    <Color x:Key="HoverYellow">#FFE066</Color>
    <Color x:Key="PressedYellow">#B99824</Color>
    <Color x:Key="ErrorRed">#E05260</Color>
    <Color x:Key="ErrorRedDark">#B73A45</Color>
    <Color x:Key="WarningOrange">#FFB020</Color>
    <Color x:Key="White">#FFFFFF</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryBlack}"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource SecondaryBlack}"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource TextLight}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#1B1F23"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryYellow}"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#111111"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverYellow}"/>
    <SolidColorBrush x:Key="PressedBrush" Color="{StaticResource PressedYellow}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3A4148"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B7C0CA"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLight}"/>
    <SolidColorBrush x:Key="TextDarkBrush" Color="#000000"/>
    <SolidColorBrush x:Key="PrimaryBlackBrush" Color="#111111"/>
    <SolidColorBrush x:Key="TabActiveBrush" Color="{StaticResource PrimaryYellow}"/>
    <SolidColorBrush x:Key="TabInactiveBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="TabHoverBrush" Color="#30363D"/>
    <SolidColorBrush x:Key="ErrorRedBrush" Color="{StaticResource ErrorRed}"/>
    <SolidColorBrush x:Key="ErrorRedDarkBrush" Color="{StaticResource ErrorRedDark}"/>
    <SolidColorBrush x:Key="WarningOrangeBrush" Color="{StaticResource WarningOrange}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#1B1F23"/>
    <SolidColorBrush x:Key="ReadOnlyBackgroundBrush" Color="#242A30"/>
    <SolidColorBrush x:Key="RowAlternateBrush" Color="#1D2227"/>
    <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#2B3138"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="#705D1F"/>
    <SolidColorBrush x:Key="SelectionForegroundBrush" Color="#FFFFFF"/>

</ResourceDictionary>
