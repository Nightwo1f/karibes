<Application x:Class="Karibes.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Karibes.App.Views"
             xmlns:viewModels="clr-namespace:Karibes.App.ViewModels"
             xmlns:converters="clr-namespace:Karibes.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
                <ResourceDictionary Source="Resources/Icons.xaml"/>
                <!-- Tema será carregado dinamicamente pelo TemaService -->
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converters -->
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:CreditoDisponivelConverter x:Key="CreditoDisponivelConverter"/>
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <converters:NullToBooleanConverter x:Key="NullToBooleanConverter"/>
            <converters:DecimalGreaterThanZeroConverter x:Key="DecimalGreaterThanZeroConverter"/>
            <converters:DecimalLessThanZeroConverter x:Key="DecimalLessThanZeroConverter"/>
            <converters:SubtractConverter x:Key="SubtractConverter"/>
            
            <!-- DataTemplates: Associam automaticamente ViewModels às Views -->
            <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewModels:ProdutosViewModel}">
                <views:ProdutosView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewModels:ClientesViewModel}">
                <views:ClientesView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewModels:VendasViewModel}">
                <views:VendasView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewModels:FinanceiroViewModel}">
                <views:FinanceiroView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type viewModels:RelatoriosViewModel}">
                <views:RelatoriosView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>

