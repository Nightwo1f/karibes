<UserControl x:Class="Karibes.App.Views.VendasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" 
                Background="{DynamicResource PanelBrush}" 
                Padding="20,15"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="💰 Gestão de Vendas" 
                           FontSize="24" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ Nova Venda" 
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding NovaVendaCommand}"
                            Margin="5,0"/>
                    <Button Content="🔄 Atualizar" 
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CarregarVendasCommand}"
                            Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Conteúdo Principal -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Lista de Vendas -->
                <ColumnDefinition Width="2*"/>
                <!-- Nova Venda / Detalhes -->
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ============================================ -->
            <!-- LISTA DE VENDAS -->
            <!-- ============================================ -->
            <Border Grid.Column="0" 
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,10,0"
                    Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filtros -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Filtros" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,10"/>

                        <!-- Período -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <DatePicker Grid.Column="0"
                                        SelectedDate="{Binding FiltroDataInicio}"
                                        Style="{StaticResource ModernDatePicker}"/>
                            <TextBlock Grid.Column="1" 
                                       Text="até" 
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       HorizontalAlignment="Center"/>
                            <DatePicker Grid.Column="2"
                                        SelectedDate="{Binding FiltroDataFim}"
                                        Style="{StaticResource ModernDatePicker}"/>
                        </Grid>

                        <!-- Cliente -->
                        <TextBox Text="{Binding FiltroCliente, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,10"
                                 Tag="Buscar cliente..."/>

                        <!-- Forma de Pagamento -->
                        <ComboBox SelectedValue="{Binding FiltroFormaPagamento}"
                                  SelectedValuePath="Content"
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,10">
                            <ComboBoxItem Content="Todas"/>
                            <ComboBoxItem Content="Dinheiro"/>
                            <ComboBoxItem Content="Cartão"/>
                            <ComboBoxItem Content="Pix"/>
                            <ComboBoxItem Content="Crédito"/>
                        </ComboBox>

                        <!-- Status -->
                        <ComboBox SelectedValue="{Binding FiltroStatus}"
                                  SelectedValuePath="Content"
                                  Style="{StaticResource ModernComboBox}">
                            <ComboBoxItem Content="Todas"/>
                            <ComboBoxItem Content="Finalizada"/>
                            <ComboBoxItem Content="Pendente"/>
                            <ComboBoxItem Content="Cancelada"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,10">
                        <Button Content="Cancelar Venda"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding CancelarVendaCommand}"
                                Padding="12,6"/>
                    </StackPanel>

                    <!-- DataGrid de Vendas -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Vendas}"
                              SelectedItem="{Binding VendaSelecionada}"
                              Style="{StaticResource ModernDataGrid}"
                              AutoGenerateColumns="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              SelectionMode="Single"
                              GridLinesVisibility="All"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" 
                                                Binding="{Binding Id}" 
                                                Width="50"/>
                            <DataGridTextColumn Header="Número" 
                                                Binding="{Binding NumeroVenda}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Cliente" 
                                                Binding="{Binding Cliente.Nome}" 
                                                Width="*"/>
                            <DataGridTextColumn Header="Valor" 
                                                Binding="{Binding ValorTotal, StringFormat=C2}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Pagamento" 
                                                Binding="{Binding FormaPagamento}" 
                                                Width="80"/>
                            <DataGridTextColumn Header="Status" 
                                                Binding="{Binding Status}" 
                                                Width="80"/>
                            <DataGridTextColumn Header="Data" 
                                                Binding="{Binding DataVenda, StringFormat=dd/MM/yyyy HH:mm}" 
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ============================================ -->
            <!-- NOVA VENDA / DETALHES -->
            <!-- ============================================ -->
            <Border Grid.Column="1" 
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Título -->
                        <TextBlock Text="Nova Venda" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,20"/>

                        <!-- Seleção de Cliente -->
                        <TextBlock Text="Cliente (opcional para venda à vista)" 
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      SelectedItem="{Binding ClienteSelecionado}"
                                      ItemsSource="{Binding ClientesDisponiveis}"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,10,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Nome}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Codigo, StringFormat='Código: {}{0}'}" 
                                                       FontSize="11" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBox Grid.Column="1"
                                     Text="{Binding BuscaCliente, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Width="200"
                                     Tag="Buscar cliente..."/>
                        </Grid>

                        <!-- Informações de Crédito (se fiado) -->
                        <Border Background="{DynamicResource BackgroundBrush}"
                                Padding="10"
                                CornerRadius="4"
                                Margin="0,0,0,15"
                                Visibility="{Binding ClienteSelecionado, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Informações de Crédito" 
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding ClienteSelecionado.LimiteCredito, StringFormat='Limite: R$ {}{0:N2}'}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding ClienteSelecionado.SaldoDevedor, StringFormat='Saldo Devedor: R$ {}{0:N2}'}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding ClienteSelecionado, Converter={StaticResource CreditoDisponivelConverter}}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- Adicionar Produto -->
                        <TextBlock Text="Adicionar Produto" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      SelectedItem="{Binding ProdutoSelecionado}"
                                      ItemsSource="{Binding ProdutosDisponiveis}"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,10,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Nome}" FontWeight="SemiBold"/>
                                            <TextBlock FontSize="11" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Cód: {}{0} | Estoque: {}{1} | R$ {}{2:N2}">
                                                        <Binding Path="Codigo"/>
                                                        <Binding Path="Estoque"/>
                                                        <Binding Path="Preco"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBox Grid.Column="1"
                                     Text="{Binding QuantidadeAdicionar, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Margin="0,0,10,0"/>

                            <Button Grid.Column="2"
                                    Content="➕ Adicionar" 
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AdicionarItemCarrinhoCommand}"/>
                        </Grid>

                        <!-- Busca de Produto -->
                        <TextBox Text="{Binding BuscaProduto, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,15"
                                 Tag="Buscar produto por nome ou código..."/>

                        <!-- Carrinho -->
                        <TextBlock Text="Carrinho de Compras" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,10"/>

                        <DataGrid ItemsSource="{Binding ItensCarrinho}"
                                  Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  Margin="0,0,0,15"
                                  MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Produto" 
                                                    Binding="{Binding Produto.Nome}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Qtd" 
                                                    Binding="{Binding Quantidade}" 
                                                    Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Preço Unit." 
                                                    Binding="{Binding PrecoUnitario, StringFormat=C2}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Total" 
                                                    Binding="{Binding ValorTotal, StringFormat=C2}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="❌" 
                                                    Style="{StaticResource PrimaryButton}"
                                                    Padding="8,4"
                                                    Command="{Binding DataContext.RemoverItemCarrinhoCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Totais -->
                        <Border Background="{DynamicResource BackgroundBrush}"
                                Padding="15"
                                CornerRadius="4"
                                Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Subtotal:" 
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding SubtotalVendaTexto, Mode=OneWay}"
                                             Style="{StaticResource ModernTextBox}"
                                             Width="130"
                                             IsReadOnly="True"
                                             IsTabStop="False"
                                             HorizontalContentAlignment="Right"/>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Desconto:" 
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding DescontoVenda, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"
                                             Width="120"
                                             HorizontalAlignment="Right"/>
                                </Grid>

                                <Separator Grid.Row="2" Margin="0,5"/>

                                <Grid Grid.Row="3" Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Total:" 
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding TotalVendaTexto, Mode=OneWay}"
                                             Style="{StaticResource ModernTextBox}"
                                             Width="130"
                                             IsReadOnly="True"
                                             IsTabStop="False"
                                             FontSize="18"
                                             FontWeight="Bold"
                                             Foreground="{DynamicResource AccentBrush}"
                                             HorizontalContentAlignment="Right"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Forma de Pagamento -->
                        <TextBlock Text="Forma de Pagamento" 
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,5"/>
                        <ComboBox SelectedValue="{Binding FormaPagamento}"
                                  SelectedValuePath="Content"
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,15">
                            <ComboBoxItem Content="Dinheiro"/>
                            <ComboBoxItem Content="Cartão"/>
                            <ComboBoxItem Content="Pix"/>
                            <ComboBoxItem Content="Crédito"/>
                        </ComboBox>

                        <!-- Vendedor e Observações -->
                        <Grid Margin="0,0,0,15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="Vendedor" 
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Vendedor}"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1">
                                <TextBlock Text="Observações" 
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ObservacoesVenda}"
                                         Style="{StaticResource ModernTextBox}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="60"/>
                            </StackPanel>
                        </Grid>

                        <!-- Botões de Ação -->
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Right"
                                    Margin="0,20,0,0">
                            <Button Content="Limpar"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding LimparCarrinhoCommand}"
                                    Padding="20,10"
                                    Margin="0,0,10,0"/>
                            <Button Content="Confirmar Venda"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ConfirmarVendaCommand}"
                                    Padding="20,10"
                                    FontSize="14"
                                    FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Aviso de Crédito -->
                        <Border Background="{DynamicResource WarningOrangeBrush}"
                                Padding="10"
                                CornerRadius="4"
                                Margin="0,15,0,0"
                                Visibility="{Binding PodeVenderFiado, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="⚠️ Cliente possui limite de crédito suficiente para esta venda."
                                       Foreground="Black"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>

