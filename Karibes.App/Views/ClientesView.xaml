<UserControl x:Class="Karibes.App.Views.ClientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Karibes.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" 
                Background="{DynamicResource PanelBrush}" 
                Padding="20,15"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="👥 Clientes" 
                           FontSize="24" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ Novo Cliente" 
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding NovoClienteCommand}"
                            Margin="5,0"/>
	                    <Button Content="🔄 Atualizar" 
	                            Style="{StaticResource PrimaryButton}"
	                            Command="{Binding AtualizarCommand}"
	                            Margin="5,0"/>
	                    <Button Content="Exportar PDF" 
	                            Style="{StaticResource SecondaryButton}"
	                            Command="{Binding ExportarPdfCommand}"
	                            Margin="5,0"/>
	                </StackPanel>
            </Grid>
        </Border>

        <!-- Conteúdo Principal -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Lista de Clientes -->
                <ColumnDefinition Width="*"/>
                <!-- Formulário de Edição (condicional) -->
                <ColumnDefinition Width="0">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsModalAberto}" Value="True">
                                    <Setter Property="Width" Value="400"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- ============================================ -->
            <!-- LISTA DE CLIENTES -->
            <!-- ============================================ -->
            <Border Grid.Column="0" 
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,10,0"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filtros -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Buscar" 
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding TextoBusca, UpdateSourceTrigger=PropertyChanged}"                                
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,10"
                                 Tag="Buscar por nome, CPF/CNPJ, telefone ou ID..."/>

                        <TextBlock Text="Status" 
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,5"/>
                        <ComboBox SelectedValue="{Binding StatusSelecionado}"
                                  SelectedValuePath="Content"
                                  Style="{StaticResource ModernComboBox}">
                            <ComboBoxItem Content="Todos"/>
                            <ComboBoxItem Content="Ativo"/>
                            <ComboBoxItem Content="Inativo"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ClientesFiltrados}"
                              SelectedItem="{Binding ClienteSelecionado}"
                              Style="{StaticResource ModernDataGrid}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
	                              GridLinesVisibility="All"
	                              HeadersVisibility="Column">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DividaVencida}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ErrorRedBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DividaProximaVencimento}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource WarningOrangeBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditarClienteCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" 
                                                Binding="{Binding Id}" 
                                                Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Nome" 
                                                Binding="{Binding Nome}" 
                                                Width="*"/>
                            <DataGridTextColumn Header="Telefone" 
                                                Binding="{Binding Telefone}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="Tipo" 
                                                Binding="{Binding TipoDocumento}" 
                                                Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
	                            <DataGridTextColumn Header="Crédito Disponível" 
                                                Width="130">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="R$ {}{0:N2}">
                                        <MultiBinding.Converter>
                                            <converters:SubtractConverter/>
                                        </MultiBinding.Converter>
                                        <Binding Path="LimiteCredito"/>
                                        <Binding Path="SaldoDevedor"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
	                            <DataGridCheckBoxColumn Header="Ativo" 
	                                                    Binding="{Binding Ativo}" 
	                                                    Width="60"/>
	                        </DataGrid.Columns>
	                    </DataGrid>

                        <Border Grid.Row="2"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                Padding="10"
                                Margin="0,10,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Compras do cliente selecionado"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,8"/>
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding ComprasCliente}"
                                          Style="{StaticResource ModernDataGrid}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Data" Binding="{Binding DataVenda, StringFormat='{}{0:dd/MM/yyyy}'}" Width="95"/>
                                        <DataGridTextColumn Header="Venda" Binding="{Binding NumeroVenda}" Width="90"/>
                                        <DataGridTextColumn Header="Pagamento" Binding="{Binding FormaPagamento}" Width="110"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                                        <DataGridTextColumn Header="Total" Binding="{Binding ValorTotal, StringFormat='R$ {}{0:N2}'}" Width="110"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
	                </Grid>
	            </Border>

            <!-- ============================================ -->
            <!-- FORMULÁRIO DE EDIÇÃO -->
            <!-- ============================================ -->
            <Border Grid.Column="1" 
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Padding="20"
                    Margin="10,0,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsModalAberto}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Dados do Cliente" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,20"/>

                        <!-- Nome / Razão Social -->
                        <TextBlock Text="Nome / Razão Social *" 
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ClienteEditando.Nome, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,15"/>

                        <!-- Tipo de Documento e Documento -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      SelectedValue="{Binding ClienteEditando.TipoDocumento}"
                                      SelectedValuePath="Content"
                                      Width="100"
                                      Margin="0,0,10,0"
                                      Style="{StaticResource ModernComboBox}">
                                <ComboBoxItem Content="CPF"/>
                                <ComboBoxItem Content="CNPJ"/>
                            </ComboBox>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ClienteEditando.Documento, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                        </Grid>

                        <!-- Telefone e Celular -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Telefone" 
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ClienteEditando.Telefone, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Celular" 
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ClienteEditando.Celular, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Email -->
                        <TextBlock Text="Email" 
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ClienteEditando.Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,15"/>

                        <!-- Limite de Crédito -->
                        <TextBlock Text="Limite de Crédito" 
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ClienteEditando.LimiteCredito, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource ZeroToEmptyConverter}}"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,15"/>

                        <TextBlock Text="Vencimento do cr�dito" 
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding ClienteEditando.DataVencimentoCredito}"
                                    Style="{StaticResource ModernDatePicker}"
                                    Margin="0,0,0,15"/>

                        <!-- Status -->
                        <CheckBox Content="Cliente Ativo" 
                                  IsChecked="{Binding ClienteEditando.Ativo}"
                                  Foreground="{DynamicResource ForegroundBrush}"
                                  Margin="0,0,0,15"/>

                        <!-- Observações -->
                        <TextBlock Text="Observações" 
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ClienteEditando.Observacoes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="60"
                                 Margin="0,0,0,20"/>

                        <!-- Informações Financeiras -->
                        <Border Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="15"
                                Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Informações Financeiras" 
                                           FontSize="16" 
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Saldo Devedor" 
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding ClienteEditando.SaldoDevedor, StringFormat='R$ {}{0:N2}'}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold"
                                                   Foreground="Red"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Total Pago" 
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding ClienteEditando.TotalPago, StringFormat='R$ {}{0:N2}'}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold"
                                                   Foreground="Green"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Abatimento de Dívida -->
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="15"
                                Margin="0,0,0,20">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ClienteEditando.SaldoDevedor, Converter={StaticResource DecimalGreaterThanZeroConverter}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="💳 Abater Dívida" 
                                           FontSize="16" 
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,15"/>
                                
                                <TextBlock Text="Valor do Pagamento" 
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ValorPagamento, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource ZeroToEmptyConverter}}"
                                         Style="{StaticResource ModernTextBox}"
                                         Margin="0,0,0,10"/>

                                <TextBlock Text="Data do Pagamento" 
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,5"/>
                                <DatePicker SelectedDate="{Binding DataPagamento}"
                                             Style="{StaticResource ModernDatePicker}"
                                             Margin="0,0,0,10"/>

                                <TextBlock Text="Observação" 
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ObservacaoPagamento, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="50"
                                         Margin="0,0,0,10"/>

                                <Button Content="✅ Registrar Pagamento" 
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding RegistrarPagamentoCommand}"
                                        HorizontalAlignment="Right"
                                        Padding="20,8"/>
                            </StackPanel>
                        </Border>

                        <!-- Histórico de Compras -->
                        <TextBlock Text="📦 Histórico de Compras" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,10"/>
                        <DataGrid ItemsSource="{Binding ComprasCliente}"
                                  Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  HeadersVisibility="Column"
                                  MaxHeight="200"
                                  Margin="0,0,0,20">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data" 
                                                    Binding="{Binding DataVenda, StringFormat='{}{0:dd/MM/yyyy}'}" 
                                                    Width="100"/>
                                <DataGridTextColumn Header="Nº Venda" 
                                                    Binding="{Binding NumeroVenda}" 
                                                    Width="100"/>
                                <DataGridTextColumn Header="Valor Total" 
                                                    Binding="{Binding ValorTotal, StringFormat='R$ {}{0:N2}'}" 
                                                    Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Forma Pagamento" 
                                                    Binding="{Binding FormaPagamento}" 
                                                    Width="120"/>
                                <DataGridTextColumn Header="Status" 
                                                    Binding="{Binding Status}" 
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Botões de Ação -->
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Right"
                                    Margin="0,10,0,0">
                            <Button Content="💾 Salvar" 
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SalvarClienteCommand}"
                                    Margin="0,0,10,0"
                                    Padding="20,8"/>
                            <Button Content="Cancelar" 
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CancelarEdicaoCommand}"
                                    Padding="20,8"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>


