<UserControl x:Class="Karibes.App.Views.TrocaDevolucaoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" 
                Background="{StaticResource PanelBrush}" 
                Padding="20,15"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="🔄 Trocas e Devoluções" 
                           FontSize="24" 
                           FontWeight="Bold"
                           Foreground="{StaticResource ForegroundBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="🗑️ Limpar" 
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LimparCommand}"
                        Padding="15,8"/>
            </Grid>
        </Border>

        <!-- Conteúdo Principal -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,20">
                <!-- Busca de Venda -->
                <Border Background="{StaticResource SecondaryBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Buscar Venda" 
                                       FontSize="16" 
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ForegroundBrush}"
                                       Margin="0,0,0,10"/>
                            <TextBox Text="{Binding NumeroVendaBusca}"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="Número da venda (ex: VENDA-20240101120000-1234)"
                                     Margin="0,0,10,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="🔍 Buscar" 
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BuscarVendaCommand}"
                                Padding="20,10"
                                VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>

                <!-- Informações da Venda -->
                <Border Background="{StaticResource SecondaryBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,15"
                        Visibility="{Binding VendaSelecionada, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Informações da Venda" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ForegroundBrush}"
                                   Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Número da Venda -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Text="Número" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding VendaSelecionada.NumeroVenda}" 
                                           Foreground="{StaticResource ForegroundBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Cliente -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,10">
                                <TextBlock Text="Cliente" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding VendaSelecionada.Cliente.Nome}" 
                                           Foreground="{StaticResource ForegroundBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Data -->
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                                <TextBlock Text="Data" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding VendaSelecionada.DataVenda, StringFormat=dd/MM/yyyy HH:mm}" 
                                           Foreground="{StaticResource ForegroundBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Forma de Pagamento -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Text="Forma de Pagamento" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding VendaSelecionada.FormaPagamento}" 
                                           Foreground="{StaticResource ForegroundBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Status -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,10">
                                <TextBlock Text="Status" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding VendaSelecionada.Status}" 
                                           Foreground="{StaticResource ForegroundBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Valor Total -->
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                                <TextBlock Text="Valor Total" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding VendaSelecionada.ValorTotal, StringFormat=C2}" 
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="Bold"
                                           FontSize="16"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Modo de Operação -->
                <Border Background="{StaticResource SecondaryBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,15"
                        Visibility="{Binding VendaSelecionada, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Tipo de Operação" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ForegroundBrush}"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="📤 Devolução" 
                                         IsChecked="{Binding IsModoDevolucao}"
                                         Foreground="{StaticResource ForegroundBrush}"
                                         Margin="0,0,15,0"/>
                            <RadioButton Content="🔄 Troca" 
                                         IsChecked="{Binding IsModoDevolucao, Converter={StaticResource InverseBooleanConverter}}"
                                         Foreground="{StaticResource ForegroundBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Itens da Venda para Devolução -->
                <Border Background="{StaticResource SecondaryBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,15"
                        Visibility="{Binding VendaSelecionada, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Itens da Venda" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ForegroundBrush}"
                                   Margin="0,0,0,15"/>

                        <DataGrid ItemsSource="{Binding ItensDevolucao}"
                                  Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  MaxHeight="300"
                                  CellEditEnding="DataGrid_CellEditEnding">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Produto" 
                                                    Binding="{Binding ItemVenda.Produto.Nome}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Qtd. Original" 
                                                    Binding="{Binding QuantidadeOriginal}" 
                                                    Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Qtd. Devolver" 
                                                    Binding="{Binding QuantidadeDevolver}" 
                                                    Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Valor Unit." 
                                                    Binding="{Binding ItemVenda.PrecoUnitario, StringFormat=C2}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Valor Devolver" 
                                                    Binding="{Binding ValorDevolver, StringFormat=C2}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="Red"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Total Devolução -->
                        <Border Background="{StaticResource BackgroundBrush}"
                                Padding="15"
                                CornerRadius="4"
                                Margin="0,15,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="Total a Devolver" 
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding ValorTotalDevolucao, StringFormat='R$ {}{0:N2}'}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="Red"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Novos Itens para Troca -->
                <Border Background="{StaticResource SecondaryBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,15"
                        Visibility="{Binding IsModoDevolucao, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Novos Itens para Troca" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ForegroundBrush}"
                                   Margin="0,0,0,15"/>

                        <!-- Adicionar Produto -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      SelectedItem="{Binding ProdutoSelecionado}"
                                      ItemsSource="{Binding ProdutosDisponiveis}"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,10,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Nome}" FontWeight="SemiBold"/>
                                            <TextBlock FontSize="11" 
                                                       Foreground="{StaticResource TextSecondaryBrush}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Cód: {}{0} | Estoque: {}{1} | R$ {}{2:N2}">
                                                        <Binding Path="Codigo"/>
                                                        <Binding Path="Estoque"/>
                                                        <Binding Path="Preco"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBox Grid.Column="1"
                                     Text="{Binding QuantidadeAdicionar}"
                                     Style="{StaticResource ModernTextBox}"
                                     Margin="0,0,10,0"/>

                            <Button Grid.Column="2"
                                    Content="➕ Adicionar" 
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AdicionarItemNovoCommand}"/>
                        </Grid>

                        <!-- Busca de Produto -->
                        <TextBox Text="{Binding BuscaProduto, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,15"
                                 Tag="Buscar produto por nome ou código..."/>

                        <!-- Lista de Novos Itens -->
                        <DataGrid ItemsSource="{Binding ItensNovos}"
                                  Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  MaxHeight="200"
                                  Margin="0,0,0,15">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Produto" 
                                                    Binding="{Binding Produto.Nome}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Qtd" 
                                                    Binding="{Binding Quantidade}" 
                                                    Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Preço Unit." 
                                                    Binding="{Binding PrecoUnitario, StringFormat=C2}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Total" 
                                                    Binding="{Binding ValorTotal, StringFormat=C2}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="❌" 
                                                    Style="{StaticResource PrimaryButton}"
                                                    Padding="8,4"
                                                    Click="RemoverItemNovo_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Total Novos Itens -->
                        <Border Background="{StaticResource BackgroundBrush}"
                                Padding="15"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="Total Novos Itens" 
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ForegroundBrush}"/>
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding ValorTotalNovos, StringFormat='R$ {}{0:N2}'}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="Green"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Resumo e Confirmação -->
                <Border Background="{StaticResource AccentBrush}"
                        Padding="20"
                        CornerRadius="8"
                        Margin="0,0,0,15"
                        Visibility="{Binding VendaSelecionada, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Resumo da Operação" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBlackBrush}"
                                   Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Valor Devolvido -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Valor Devolvido:" 
                                       Foreground="{StaticResource PrimaryBlackBrush}"
                                       Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding ValorTotalDevolucao, StringFormat='R$ {}{0:N2}'}"
                                       Foreground="{StaticResource PrimaryBlackBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>

                            <!-- Valor Novos (apenas em troca) -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Valor Novos Itens:" 
                                       Foreground="{StaticResource PrimaryBlackBrush}"
                                       Margin="0,0,0,5"
                                       Visibility="{Binding IsModoDevolucao, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding ValorTotalNovos, StringFormat='R$ {}{0:N2}'}"
                                       Foreground="{StaticResource PrimaryBlackBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"
                                       Visibility="{Binding IsModoDevolucao, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <!-- Diferença -->
                            <Separator Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,10"
                                       Visibility="{Binding IsModoDevolucao, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="Diferença:" 
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBlackBrush}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding DiferencaValor, StringFormat='R$ {}{0:N2}'}"
                                       FontSize="20"
                                       FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBlackBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DiferencaValor, Converter={StaticResource DecimalLessThanZeroConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DiferencaValor, Converter={StaticResource DecimalGreaterThanZeroConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="Green"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Observações -->
                <Border Background="{StaticResource SecondaryBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,15"
                        Visibility="{Binding VendaSelecionada, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Observações" 
                                   Foreground="{StaticResource ForegroundBrush}"
                                   Margin="0,0,0,10"/>
                        <TextBox Text="{Binding Observacao}"
                                 Style="{StaticResource ModernTextBox}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="80"/>
                    </StackPanel>
                </Border>

                <!-- Botões de Ação -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Visibility="{Binding VendaSelecionada, Converter={StaticResource NullToVisibilityConverter}}">
                    <Button Content="✅ Confirmar Devolução" 
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ConfirmarDevolucaoCommand}"
                            Padding="20,12"
                            Margin="0,0,10,0"
                            FontSize="14"
                            FontWeight="Bold"
                            Visibility="{Binding IsModoDevolucao, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="✅ Confirmar Troca" 
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ConfirmarTrocaCommand}"
                            Padding="20,12"
                            FontSize="14"
                            FontWeight="Bold"
                            Visibility="{Binding IsModoDevolucao, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

