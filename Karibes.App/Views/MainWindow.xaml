<Window x:Class="Karibes.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Karibes - Sistema de Gestao" 
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar fixa -->
            <ColumnDefinition Width="250"/>
            <!-- Area de conteudo -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- ============================================ -->
        <!-- SIDEBAR FIXA -->
        <!-- ============================================ -->
        <Border Grid.Column="0" 
                Background="{DynamicResource PanelBrush}" 
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Cabecalho da Sidebar -->
                    <RowDefinition Height="Auto"/>
                    <!-- Botoes de Navegacao -->
                    <RowDefinition Height="*"/>
                    <!-- Seletor de Tema -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Cabecalho: Nome do Sistema -->
                <Border Grid.Row="0" 
                        Background="{DynamicResource AccentBrush}" 
                        Padding="20,25">
                    <TextBlock Text="KARIBES" 
                               FontSize="28" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBlackBrush}"
                               HorizontalAlignment="Center"/>
                </Border>
                
                <!-- Botoes de Navegacao -->
                <StackPanel Grid.Row="1" 
                            Margin="10,20,10,10" 
                            VerticalAlignment="Top">
                    
                    <Button Content="Dashboard" 
                            Command="{Binding NavigateToDashboardCommand}"
                            Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AbaAtiva}" Value="Dashboard">
                                        <Setter Property="Background" Value="{DynamicResource TabActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBlackBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <Button Content="Produtos" 
                            Command="{Binding NavigateToProdutosCommand}"
                            Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AbaAtiva}" Value="Produtos">
                                        <Setter Property="Background" Value="{DynamicResource TabActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBlackBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <Button Content="Clientes" 
                            Command="{Binding NavigateToClientesCommand}"
                            Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AbaAtiva}" Value="Clientes">
                                        <Setter Property="Background" Value="{DynamicResource TabActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBlackBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <Button Content="Vendas" 
                            Command="{Binding NavigateToVendasCommand}"
                            Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AbaAtiva}" Value="Vendas">
                                        <Setter Property="Background" Value="{DynamicResource TabActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBlackBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <Button Content="Trocas" 
                            Command="{Binding NavigateToTrocasCommand}"
                            Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AbaAtiva}" Value="Trocas">
                                        <Setter Property="Background" Value="{DynamicResource TabActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBlackBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <Button Content="Financeiro" 
                            Command="{Binding NavigateToFinanceiroCommand}"
                            Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AbaAtiva}" Value="Financeiro">
                                        <Setter Property="Background" Value="{DynamicResource TabActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBlackBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <Button Content="Relatorios" 
                            Command="{Binding NavigateToRelatoriosCommand}"
                            Margin="0,0,0,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AbaAtiva}" Value="Relatorios">
                                        <Setter Property="Background" Value="{DynamicResource TabActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBlackBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                
                <!-- Seletor de Tema na parte inferior -->
                <Border Grid.Row="2" 
                        Background="{DynamicResource SecondaryBackgroundBrush}" 
                        Padding="15"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="Tema:" 
                                   Foreground="{DynamicResource ForegroundBrush}" 
                                   FontSize="12"
                                   Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Claro" 
                                    Style="{StaticResource ThemeButton}" 
                                    Margin="2"
                                    Command="{Binding AlterarTemaCommand}"
                                    CommandParameter="Light"/>
                            <Button Content="Escuro" 
                                    Style="{StaticResource ThemeButton}" 
                                    Margin="2"
                                    Command="{Binding AlterarTemaCommand}"
                                    CommandParameter="Dark"/>
                            <Button Content="Karibes" 
                                    Style="{StaticResource ThemeButton}" 
                                    Margin="2"
                                    Command="{Binding AlterarTemaCommand}"
                                    CommandParameter="Karibes"/>
                        </StackPanel>

                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Margin="0,12,0,0"
                                Padding="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Banco SQLite"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding BancoDadosPath}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="10"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <Button Content="Abrir pasta"
                                        Style="{StaticResource ThemeButton}"
                                        Margin="0,0,0,6"
                                        Command="{Binding AbrirPastaBancoCommand}"/>
                                <Button Content="Backup agora"
                                        Style="{StaticResource ThemeButton}"
                                        Command="{Binding CriarBackupBancoCommand}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- ============================================ -->
        <!-- AREA DE CONTEUDO -->
        <!-- ============================================ -->
        <ContentControl Grid.Column="1" 
                        Content="{Binding CurrentViewModel}"
                        Margin="20">
            <!-- DataTemplate sera aplicado automaticamente baseado no tipo do ViewModel -->
        </ContentControl>
    </Grid>
</Window>




